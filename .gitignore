# =============================================================================
# .gitignore — Plugin JeeWhatsApp
# Ne versionner que ce qui est nécessaire au fonctionnement du plugin.
# =============================================================================

# ── Fichiers Claude Code (développement) ─────────────────────────────────────
CLAUDE.md
.claude/

# ── Fichiers de planification / développement (non publiés) ──────────────────
ROADMAP.md
SECURITY-AUDIT.md
DEV-WORKFLOW.md

# ── Scripts de test / validation internes ────────────────────────────────────
tools/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Dépendances Node.js — installées par install_dep.sh ──────────────────────
# Ne pas versionner node_modules : npm install les reconstruit à partir de package.json
resources/jeewhatsappd/node_modules/
# package-lock.json n'est pas versionné : il devient stale à chaque bump de dépendance
# transitoire et bloque l'installation (npm ci échoue). npm install regénère le lock local.
resources/jeewhatsappd/package-lock.json

# ── Credentials Baileys (générés à l'exécution, SENSIBLES) ───────────────────
# Contient les clés de session WhatsApp — jamais dans le dépôt
resources/jeewhatsappd/auth/

# ── Piper TTS — binaire et modèles vocaux (lourds, installés par install_dep.sh) ──
resources/piper/piper/
resources/piper/voices/
resources/piper/*.tar.gz
resources/piper/*.gz

# ── Vosk STT — modèles de langue (lourds, installés par install_dep.sh) ──────
resources/stt/model-*/
resources/stt/*.zip
resources/stt/__pycache__/
resources/stt/*.pyc

# ── Dossier parasite (doublon généré par erreur) ──────────────────────────────
jeewhatsapp/

# ── Sauvegardes de session chiffrées (générées par l'utilisateur) ────────────
*.jwab
*.jwab.bak
*.jwab.gz

# ── Logs et fichiers temporaires ─────────────────────────────────────────────
*.log
*.tmp
*.pid

# ── Données Jeedom (médias entrants — non versionnés) ────────────────────────
data/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Éditeur ───────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
*.bak
*.orig
